        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "definition": "label_values(up, job)",
        "includeAll": true,
        "multi": true,
        "name": "service",
        "query": { "query": "label_values(up, job)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "regex": "/(api-gateway|auth-service|user-service|payment-service|wallet-service|notification-service|service-registry)/",
        "type": "query"
      }
    ]
